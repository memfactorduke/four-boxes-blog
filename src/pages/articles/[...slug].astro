---
import BaseLayout from '../../layouts/BaseLayout.astro';
import VideoEmbed from '../../components/VideoEmbed.astro';
import MetadataSidebar from '../../components/MetadataSidebar.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map(article => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
const { data } = article;

const formattedDate = new Date(data.date + 'T00:00:00').toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={data.title} description={data.title} image={data.thumbnail}>
  <!-- Article header band -->
  <div class="bg-obsidian relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(255,255,255,0.04)_0%,transparent_70%)]"></div>
    <div class="relative max-w-7xl mx-auto px-5 lg:px-8 py-10 md:py-14">
      <nav class="text-xs text-white/40 mb-5 flex items-center gap-2 animate-fade-in font-[Figtree]">
        <a href="/" class="hover:text-brass transition-colors">Home</a>
        <svg class="w-3 h-3 text-brass/30" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg>
        <span class="text-white/60 truncate max-w-xs">{data.title}</span>
      </nav>

      <div class="animate-fade-up">
        <div class="flex flex-wrap gap-2 mb-4">
          {data.content_type.map(type => (
            <span class="bg-brass/15 text-brass text-[10px] font-bold px-2.5 py-1 rounded uppercase tracking-wider font-[Figtree]">
              {type.replace(/-/g, ' ')}
            </span>
          ))}
          {data.court_level.map(level => (
            <span class="bg-white/10 text-white/70 text-[10px] font-bold px-2.5 py-1 rounded uppercase tracking-wider font-[Figtree]">
              {level}
            </span>
          ))}
        </div>

        <h1 class="font-[Fraunces] text-3xl md:text-4xl lg:text-5xl font-bold text-white leading-tight tracking-tight mb-4 max-w-3xl text-balance">
          {data.title}
        </h1>

        <div class="flex items-center gap-3 text-sm text-white/50 font-[Figtree]">
          <div class="flex items-center gap-2">
            <div class="w-7 h-7 rounded-full bg-gradient-to-br from-brass/40 to-brass/20 flex items-center justify-center">
              <span class="text-[10px] text-brass font-bold font-[Fraunces]">MWS</span>
            </div>
            <span class="text-white/70 font-medium">{data.author}</span>
          </div>
          <span class="w-1 h-1 rounded-full bg-white/20"></span>
          <time>{formattedDate}</time>
          <span class="w-1 h-1 rounded-full bg-white/20"></span>
          <span>{data.duration}</span>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-5 lg:px-8 py-10">
    <div class="grid lg:grid-cols-[1fr_320px] gap-10">
      <!-- Article Content -->
      <article data-pagefind-body class="animate-fade-up stagger-1">
        <VideoEmbed youtube_id={data.youtube_id} title={data.title} />

        {data.pull_quote && (
          <div class="my-8 relative">
            <div class="border-l-4 border-[#6b2029] rounded-r-md px-6 py-5 md:px-8 md:py-6 bg-parchment/60">
              <div class="absolute top-3 left-4 font-[Fraunces] text-6xl text-brass/15 leading-none select-none">&ldquo;</div>
              <div class="flex items-center gap-2 mb-3 relative">
                <span class="text-xs font-bold uppercase tracking-widest text-brass font-[Figtree]">Mark's Hot Take</span>
              </div>
              <blockquote class="font-[Lora] text-xl text-obsidian/90 italic leading-relaxed relative">
                {data.pull_quote}
              </blockquote>
              <div class="mt-3 flex items-center justify-between">
                <span class="text-sm text-obsidian/50 font-medium font-[Figtree]">— Mark W. Smith</span>
                <a
                  href={`https://x.com/intent/tweet?text=${encodeURIComponent(`"${data.pull_quote}"\n\n— @markwsmithlaw\n\n`)}&url=${encodeURIComponent(`https://2ablog.com/articles/${Astro.params.slug}`)}`}
                  target="_blank"
                  rel="noopener"
                  class="inline-flex items-center gap-1.5 text-xs text-obsidian/40 hover:text-obsidian/70 transition-colors group bg-obsidian/5 hover:bg-obsidian/10 px-3 py-1.5 rounded-full"
                >
                  <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                  <span class="group-hover:underline font-[Figtree]">Share on X</span>
                </a>
              </div>
            </div>
          </div>
        )}

        <div class="prose max-w-none">
          <Content />
        </div>

        <!-- Article footer: email capture -->
        <div class="mt-14 pt-10 border-t border-gray-100">
          <div class="bg-obsidian rounded-md p-8 md:p-10">
            <div class="max-w-md">
              <h3 class="font-[Fraunces] text-xl font-bold text-white mb-2">Get the Weekly Briefing</h3>
              <p class="text-sm text-white/60 leading-relaxed mb-5 font-[Lora]">
                New analysis delivered every week. Court decisions, case updates, and expert commentary.
              </p>
              <form id="article-email-form" name="newsletter-article" method="POST" data-netlify="true" class="flex gap-2">
                <input type="hidden" name="form-name" value="newsletter-article" />
                <input
                  type="email"
                  name="email"
                  placeholder="you@example.com"
                  required
                  class="flex-1 bg-white/10 border border-white/15 rounded-md px-4 py-2.5 text-sm text-white placeholder:text-white/30 focus:outline-none focus:border-brass focus:ring-2 focus:ring-brass/15 transition-all font-[Figtree]"
                />
                <button
                  type="submit"
                  class="bg-brass text-obsidian-dark px-5 py-2.5 rounded-md text-sm font-semibold hover:bg-brass-light transition-colors whitespace-nowrap font-[Figtree]"
                >
                  Subscribe
                </button>
              </form>
              <div id="article-email-success" class="hidden mt-4 text-sm text-brass font-medium flex items-center gap-2 font-[Figtree]">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg>
                You're subscribed!
              </div>
            </div>
          </div>
        </div>
      </article>

      <!-- Sidebar -->
      <div class="animate-slide-right stagger-2 lg:sticky lg:top-24 lg:self-start">
        <MetadataSidebar
          cases_discussed={data.cases_discussed}
          court_level={data.court_level}
          circuits={data.circuits}
          states={data.states}
          legal_topics={data.legal_topics}
          case_status={data.case_status}
          content_type={data.content_type}
          tags={data.tags}
          youtube_url={data.youtube_url}
          date={data.date}
          duration={data.duration}
        />
      </div>
    </div>
  </div>

  <script is:inline>
    document.getElementById('article-email-form')?.addEventListener('submit', async function(e) {
      e.preventDefault();
      const success = document.getElementById('article-email-success');
      const btn = this.querySelector('button');
      btn.textContent = 'Subscribing...';
      btn.disabled = true;
      try {
        await fetch('/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams(new FormData(this)).toString(),
        });
        this.style.display = 'none';
        success.classList.remove('hidden');
      } catch {
        btn.textContent = 'Try Again';
        btn.disabled = false;
      }
    });
  </script>
</BaseLayout>
