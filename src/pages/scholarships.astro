---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Scholarships" description="Second Amendment scholarship opportunities">
  <div class="bg-navy">
    <div class="max-w-7xl mx-auto px-5 lg:px-8 py-12">
      <div class="text-xs text-gold font-semibold tracking-[0.2em] uppercase mb-2 animate-fade-up">Opportunities</div>
      <h1 class="font-[Playfair_Display] text-3xl font-bold text-white tracking-tight animate-fade-up stagger-1">Scholarships</h1>
      <p class="text-white/50 mt-2 text-sm font-[Newsreader] animate-fade-up stagger-2">Second Amendment scholarship opportunities</p>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-5 lg:px-8 py-16">
    <div class="text-center py-20" data-animate>
      <div class="w-16 h-16 rounded-full bg-cream border border-cream-dark flex items-center justify-center mx-auto mb-6">
        <svg class="w-7 h-7 text-navy/40" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" />
        </svg>
      </div>
      <h2 class="font-[Playfair_Display] text-2xl font-bold text-navy mb-3">Coming Soon</h2>
      <p class="text-gray-warm text-sm max-w-md mx-auto">
        Scholarship information will be available here shortly. Check back soon for details on Second Amendment legal scholarship opportunities.
      </p>
    </div>
  </div>
</BaseLayout>
