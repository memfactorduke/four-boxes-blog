---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles');

// Build topic -> article count map
const topicCounts = new Map<string, number>();
for (const article of articles) {
  for (const topic of article.data.legal_topics) {
    topicCounts.set(topic, (topicCounts.get(topic) || 0) + 1);
  }
}

// Sort by count descending
const sortedTopics = [...topicCounts.entries()].sort((a, b) => b[1] - a[1]);

function formatTopic(topic: string): string {
  return topic.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
}
---

<BaseLayout title="Topics" description="Browse Second Amendment legal analysis by topic">
  <div class="bg-obsidian">
    <div class="max-w-7xl mx-auto px-5 lg:px-8 py-12">
      <div class="text-xs text-brass font-[Figtree] font-semibold tracking-[0.2em] uppercase mb-2 animate-fade-up">Explore</div>
      <h1 class="font-[Fraunces] text-3xl font-bold text-white tracking-tight animate-fade-up stagger-1">All Topics</h1>
      <p class="text-white/50 mt-2 text-sm font-[Lora] animate-fade-up stagger-2">{sortedTopics.length} topics across {articles.length} articles</p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-5 lg:px-8 py-12">
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
      {sortedTopics.map(([topic, count], i) => (
        <a
          href={`/topics/${topic}`}
          class="group flex items-center justify-between bg-white border border-parchment-dark rounded-md px-5 py-4 hover:border-brass/30 hover:bg-brass/5 transition-all card-lift"
          data-animate
        >
          <div class="flex items-center gap-3 min-w-0">
            <div class="w-2 h-2 rounded-full bg-brass shrink-0"></div>
            <span class="font-[Fraunces] text-sm font-medium text-obsidian group-hover:text-brass-dark transition-colors truncate capitalize">
              {formatTopic(topic)}
            </span>
          </div>
          <span class="text-xs font-[Figtree] text-warm-gray bg-parchment px-2.5 py-1 rounded-full font-medium shrink-0 ml-3">
            {count}
          </span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
