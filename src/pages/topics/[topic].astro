---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  const allTopics = [...new Set(articles.flatMap(a => a.data.legal_topics))];

  return allTopics.map(topic => ({
    params: { topic },
    props: {
      topic,
      articles: articles
        .filter(a => a.data.legal_topics.includes(topic))
        .sort((a, b) => b.data.date.localeCompare(a.data.date)),
    },
  }));
}

const { topic, articles } = Astro.props;
const topicName = topic.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
---

<BaseLayout title={topicName} description={`Articles about ${topicName} — Second Amendment legal analysis`}>
  <div class="bg-obsidian">
    <div class="max-w-7xl mx-auto px-5 lg:px-8 py-12">
      <nav class="text-xs font-[Figtree] text-white/40 mb-4 flex items-center gap-2 animate-fade-in">
        <a href="/" class="hover:text-brass transition-colors">Home</a>
        <svg class="w-3 h-3 text-brass/30" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg>
        <span>Topics</span>
        <svg class="w-3 h-3 text-brass/30" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg>
        <span class="text-white/60">{topicName}</span>
      </nav>
      <h1 class="font-[Fraunces] text-3xl font-bold text-white tracking-tight animate-fade-up">{topicName}</h1>
      <p class="text-white/50 mt-2 text-sm font-[Lora] animate-fade-up stagger-1">{articles.length} article{articles.length !== 1 ? 's' : ''}</p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-5 lg:px-8 py-10">
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-7">
      {articles.map((article, i) => (
        <div data-animate class={`stagger-${Math.min(i + 1, 6)}`}>
          <ArticleCard
            title={article.data.title}
            date={article.data.date}
            slug={article.id}
            thumbnail={article.data.thumbnail}
            duration={article.data.duration}
            legal_topics={article.data.legal_topics}
            content_type={article.data.content_type}
            court_level={article.data.court_level}
            circuits={article.data.circuits}
            states={article.data.states}
            federal={article.data.federal}
          />
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
