---
// Professor 2A Chatbot - floating chat widget
---

<!-- Chat FAB Button (disabled) -->
<div
  id="chat-fab"
  class="fixed bottom-6 right-6 z-[100] group pointer-events-none opacity-40"
  aria-label="Professor 2A chat — coming soon"
>
  <div class="relative">
    <!-- Button (greyed out, no animations) -->
    <div class="relative w-16 h-16 rounded-full bg-gradient-to-br from-brass/25 via-brass/15 to-brass/5 shadow-lg flex items-center justify-center">
      <span class="text-brass/60 font-bold text-xl font-[Fraunces] leading-none">2A</span>
    </div>
    <!-- Coming Soon badge -->
    <div class="absolute -top-1 -right-1 bg-brass/20 text-brass/60 text-[7px] font-bold px-1.5 py-0.5 rounded-full uppercase tracking-wider border-2 border-paper">Soon</div>
  </div>
</div>

<!-- Chat Panel -->
<div id="chat-panel" class="fixed bottom-0 right-0 sm:bottom-6 sm:right-6 z-[101] hidden">
  <div class="w-screen sm:w-[900px] sm:max-w-[calc(100vw-2rem)] h-screen sm:h-[800px] sm:max-h-[calc(100vh-3rem)] bg-paper sm:rounded-2xl shadow-2xl border-0 sm:border border-gray-200/80 flex flex-col overflow-hidden animate-chat-open">

    <!-- Header -->
    <div class="bg-obsidian px-5 py-4 flex items-center justify-between shrink-0">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-full bg-gradient-to-br from-brass to-brass-dark flex items-center justify-center shadow-lg shadow-brass/20">
          <span class="text-obsidian font-bold text-sm font-[Fraunces]">2A</span>
        </div>
        <div>
          <div class="text-white text-sm font-semibold font-[Fraunces]">Professor 2A</div>
          <div class="text-white/40 text-[10px] uppercase tracking-wider flex items-center gap-1.5 font-[Figtree]">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 inline-block animate-pulse"></span>
            AI Legal Analysis &middot; Beta
          </div>
        </div>
      </div>
      <button id="chat-close" class="text-white/40 hover:text-white hover:bg-white/10 p-2 rounded-lg transition-all" aria-label="Close chat">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Disclaimer overlay -->
    <div id="chat-disclaimer" class="flex-1 flex flex-col items-center justify-center px-8 py-10 text-center">
      <div class="w-14 h-14 rounded-full bg-gradient-to-br from-brass to-brass-dark flex items-center justify-center mb-5 shadow-lg shadow-brass/20">
        <span class="text-obsidian font-bold text-xl font-[Fraunces]">2A</span>
      </div>
      <h2 class="font-[Fraunces] text-xl font-bold text-obsidian mb-3">Before We Begin</h2>
      <div class="text-[13px] text-ink/70 leading-relaxed space-y-3 max-w-sm font-[Lora]">
        <p><strong class="text-obsidian">Professor 2A is an AI assistant</strong> powered by analysis from constitutional attorney Mark W. Smith and The Four Boxes Diner.</p>
        <p>This tool is in <strong class="text-obsidian">beta</strong> and may occasionally produce errors. Always verify important legal information independently.</p>
        <p class="text-[12px] text-warm-gray bg-parchment rounded-lg px-4 py-3 border border-parchment-dark">
          <strong class="text-obsidian block mb-1">This is not legal advice.</strong>
          Professor 2A provides legal analysis and education only. For advice on your specific situation, consult a licensed attorney in your jurisdiction.
        </p>
      </div>
      <button id="chat-accept" class="mt-6 bg-gradient-to-r from-brass-dark to-brass text-obsidian px-8 py-3 rounded-xl font-semibold text-sm hover:shadow-xl hover:shadow-brass/20 transition-all hover:scale-[1.02] active:scale-[0.98] font-[Figtree]">
        I Understand — Let's Go
      </button>
      <p class="text-[10px] text-warm-gray mt-3 font-[Figtree]">By continuing, you acknowledge this is AI-generated analysis, not legal advice.</p>
    </div>

    <!-- Messages (hidden until disclaimer accepted) -->
    <div id="chat-messages" class="flex-1 overflow-y-auto px-6 py-5 space-y-5 hidden">
      <!-- Welcome message -->
      <div class="flex gap-3">
        <div class="w-8 h-8 rounded-full bg-gradient-to-br from-brass to-brass-dark flex items-center justify-center shrink-0 mt-0.5">
          <span class="text-obsidian text-[10px] font-bold font-[Fraunces]">2A</span>
        </div>
        <div class="bg-parchment rounded-2xl rounded-tl-sm px-4 py-3 text-[13px] text-ink leading-relaxed max-w-[85%] font-[Lora]">
          <p class="font-semibold text-obsidian">Hey there — Mark Smith here.</p>
          <p class="mt-1.5">Ask me about court cases, the <em>Bruen</em> decision, carry laws, historical tradition analysis — whatever's on your mind.</p>
        </div>
      </div>
    </div>

    <!-- Input (hidden until disclaimer accepted) -->
    <div id="chat-input-area" class="border-t border-gray-100 px-5 py-4 bg-white/80 backdrop-blur-sm shrink-0 hidden">
      <form id="chat-form" class="flex items-end gap-2.5">
        <textarea
          id="chat-input"
          rows="2"
          placeholder="Ask Professor 2A a question..."
          autocomplete="off"
          class="flex-1 bg-parchment/80 border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-brass focus:ring-2 focus:ring-brass/15 transition-all placeholder:text-warm-gray/50 resize-none leading-relaxed font-[Lora]"
        ></textarea>
        <button
          type="submit"
          id="chat-send"
          class="bg-gradient-to-r from-brass-dark to-brass text-obsidian w-11 h-11 rounded-xl flex items-center justify-center hover:shadow-lg hover:shadow-brass/20 active:scale-95 transition-all disabled:opacity-40 disabled:cursor-not-allowed shrink-0 mb-0.5"
          aria-label="Send"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.126A59.768 59.768 0 0 1 21.485 12 59.77 59.77 0 0 1 3.27 20.876L5.999 12Zm0 0h7.5"/>
          </svg>
        </button>
      </form>
    </div>
  </div>
</div>

<style is:global>
  @keyframes ping-slow {
    0% { transform: scale(1); opacity: 0.6; }
    75%, 100% { transform: scale(1.5); opacity: 0; }
  }
  .animate-ping-slow {
    animation: ping-slow 2s cubic-bezier(0, 0, 0.2, 1) infinite;
  }

  @keyframes glow-pulse {
    0%, 100% { opacity: 0.4; transform: scale(1); }
    50% { opacity: 0.8; transform: scale(1.15); }
  }
  .animate-glow-pulse {
    animation: glow-pulse 3s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-3px); }
  }
  .animate-float {
    animation: float 4s ease-in-out infinite;
  }

  @keyframes chat-open {
    from {
      opacity: 0;
      transform: translateY(16px) scale(0.92);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
  .animate-chat-open {
    animation: chat-open 0.3s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  /* Message typing indicator */
  @keyframes blink {
    0%, 80%, 100% { opacity: 0.3; }
    40% { opacity: 1; }
  }
  .typing-dot {
    animation: blink 1.4s infinite both;
  }
  .typing-dot:nth-child(2) { animation-delay: 0.2s; }
  .typing-dot:nth-child(3) { animation-delay: 0.4s; }

  /* Custom scrollbar for chat */
  #chat-messages::-webkit-scrollbar { width: 5px; }
  #chat-messages::-webkit-scrollbar-track { background: transparent; }
  #chat-messages::-webkit-scrollbar-thumb { background: #d1d5db; border-radius: 4px; }

  /* Markdown in messages */
  .chat-response p { margin-bottom: 1rem; line-height: 1.65; }
  .chat-response p:last-child { margin-bottom: 0; }
  .chat-response em { font-style: italic; }
  .chat-response strong { font-weight: 700; color: #161821; }
  .chat-response ul { padding-left: 1.25rem; margin: 0.75rem 0; list-style: disc; }
  .chat-response ol { padding-left: 1.25rem; margin: 0.75rem 0; list-style: decimal; }
  .chat-response li { margin-bottom: 0.4rem; line-height: 1.55; }
  .chat-response a {
    color: #8f7520;
    text-decoration: underline;
    text-decoration-color: #b5942d;
    text-underline-offset: 3px;
    text-decoration-thickness: 1.5px;
    font-weight: 600;
    transition: color 0.15s, text-decoration-color 0.15s;
  }
  .chat-response a:hover {
    color: #161821;
    text-decoration-color: #161821;
  }
  .chat-response h3, .chat-response h4 {
    font-weight: 700;
    color: var(--color-obsidian);
    margin: 0.5rem 0 0.25rem;
    font-size: 0.875rem;
  }
  .chat-response code {
    background: var(--color-parchment);
    padding: 0.1rem 0.3rem;
    border-radius: 3px;
    font-size: 0.8em;
  }
  .chat-response blockquote {
    border-left: 2px solid var(--color-brass);
    padding-left: 0.75rem;
    margin: 0.5rem 0;
    color: #6b7280;
    font-style: italic;
  }
</style>

<script is:inline>
(function() {
  const fab = document.getElementById('chat-fab');
  const panel = document.getElementById('chat-panel');
  const closeBtn = document.getElementById('chat-close');
  const form = document.getElementById('chat-form');
  const input = document.getElementById('chat-input');
  const messages = document.getElementById('chat-messages');
  const sendBtn = document.getElementById('chat-send');

  // Also bind header chat button
  const headerChatBtn = document.getElementById('header-chat-btn');
  const headerChatBtnMobile = document.getElementById('header-chat-btn-mobile');

  const disclaimer = document.getElementById('chat-disclaimer');
  const inputArea = document.getElementById('chat-input-area');
  const acceptBtn = document.getElementById('chat-accept');

  let history = [];
  let isStreaming = false;
  let accepted = sessionStorage.getItem('chat-accepted') === 'true';

  // If already accepted this session, skip disclaimer
  if (accepted) {
    disclaimer?.classList.add('hidden');
    messages?.classList.remove('hidden');
    inputArea?.classList.remove('hidden');
  }

  acceptBtn?.addEventListener('click', () => {
    sessionStorage.setItem('chat-accepted', 'true');
    accepted = true;
    disclaimer?.classList.add('hidden');
    messages?.classList.remove('hidden');
    inputArea?.classList.remove('hidden');
    input?.focus();
  });

  function openChat() {
    fab.classList.add('hidden');
    panel.classList.remove('hidden');
    input.focus();
  }

  function closeChat() {
    panel.classList.add('hidden');
    fab.classList.remove('hidden');
  }

  fab.addEventListener('click', openChat);
  closeBtn.addEventListener('click', closeChat);
  headerChatBtn?.addEventListener('click', openChat);
  headerChatBtnMobile?.addEventListener('click', openChat);

  // Escape to close
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !panel.classList.contains('hidden')) closeChat();
  });

  // Enter to submit (Shift+Enter for newline)
  input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      form.dispatchEvent(new Event('submit'));
    }
  });

  // Send message
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const text = input.value.trim();
    if (!text || isStreaming) return;

    const userMsg = addMessage('user', text);
    input.value = '';
    history.push({ role: 'user', content: text });

    // Scroll user message to top of chat area (like ChatGPT)
    userMsg.scrollIntoView({ behavior: 'smooth', block: 'start' });

    const typingEl = addTypingIndicator();
    isStreaming = true;
    sendBtn.disabled = true;

    try {
      const response = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: text, history: history.slice(0, -1) }),
      });

      if (!response.ok) throw new Error(`API error: ${response.status}`);

      typingEl.remove();
      const msgEl = addMessage('assistant', '');
      const contentEl = msgEl.querySelector('.chat-response');

      const reader = response.body.getReader();
      const decoder = new TextDecoder();
      let fullText = '';
      let buffer = '';
      let metaHandled = false;

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;

        buffer += decoder.decode(value, { stream: true });
        const lines = buffer.split('\n');
        buffer = lines.pop() || '';

        for (const line of lines) {
          if (!line.startsWith('data: ')) continue;
          const data = line.slice(6);
          if (data === '[DONE]') continue;

          try {
            const parsed = JSON.parse(data);

            // Handle metadata event (web search indicator)
            if (parsed.meta && !metaHandled) {
              metaHandled = true;
              if (parsed.meta.web_search) {
                const badge = document.createElement('div');
                badge.className = 'flex items-center gap-1.5 text-[10px] text-emerald-600 bg-emerald-50 border border-emerald-100 rounded-full px-2.5 py-1 mb-2 w-fit';
                badge.innerHTML = '<svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5a17.92 17.92 0 0 1-8.716-2.247m0 0A8.966 8.966 0 0 1 3 12c0-1.97.633-3.794 1.708-5.278"/></svg>Searched the web';
                contentEl.parentNode.insertBefore(badge, contentEl);
                scrollToBottom();
              }
              continue;
            }

            const delta = parsed.choices?.[0]?.delta?.content;
            if (delta) {
              fullText += delta;
              contentEl.innerHTML = renderMarkdown(fullText);
              scrollToBottom();
            }
          } catch { /* skip */ }
        }
      }

      history.push({ role: 'assistant', content: fullText });

    } catch (error) {
      typingEl?.remove();
      addMessage('assistant', 'I apologize — having trouble connecting right now. Please try again in a moment.');
      console.error('Chat error:', error);
    }

    isStreaming = false;
    sendBtn.disabled = false;
    input.focus();
  });

  function addMessage(role, text) {
    const wrapper = document.createElement('div');
    wrapper.className = 'flex gap-3' + (role === 'user' ? ' justify-end' : '');

    if (role === 'user') {
      wrapper.innerHTML = `
        <div class="bg-obsidian text-white rounded-2xl rounded-tr-sm px-4 py-3 text-[13px] leading-relaxed max-w-[80%]">
          ${escapeHtml(text)}
        </div>
      `;
    } else {
      wrapper.innerHTML = `
        <div class="w-8 h-8 rounded-full bg-gradient-to-br from-brass to-brass-dark flex items-center justify-center shrink-0 mt-0.5">
          <span class="text-obsidian text-[10px] font-bold" style="font-family: Fraunces, serif">2A</span>
        </div>
        <div class="bg-parchment rounded-2xl rounded-tl-sm px-5 py-4 text-[13px] text-ink leading-relaxed max-w-[92%]">
          <div class="chat-response">${text ? renderMarkdown(text) : ''}</div>
        </div>
      `;
    }

    messages.appendChild(wrapper);
    scrollToBottom();
    return wrapper;
  }

  function addTypingIndicator() {
    const el = document.createElement('div');
    el.className = 'flex gap-3';
    el.innerHTML = `
      <div class="w-8 h-8 rounded-full bg-gradient-to-br from-brass to-brass-dark flex items-center justify-center shrink-0 mt-0.5">
        <span class="text-obsidian text-[10px] font-bold" style="font-family: Fraunces, serif">2A</span>
      </div>
      <div class="bg-parchment rounded-2xl rounded-tl-sm px-5 py-3.5 flex gap-1.5">
        <div class="w-2 h-2 rounded-full bg-warm-gray/50 typing-dot"></div>
        <div class="w-2 h-2 rounded-full bg-warm-gray/50 typing-dot"></div>
        <div class="w-2 h-2 rounded-full bg-warm-gray/50 typing-dot"></div>
      </div>
    `;
    messages.appendChild(el);
    scrollToBottom();
    return el;
  }

  function scrollToBottom() {
    messages.scrollTop = messages.scrollHeight;
  }

  function escapeHtml(text) {
    return String(text)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function safeUrl(url) {
    if (typeof url !== 'string') return null;
    const trimmed = url.trim();
    if (!trimmed) return null;
    if (/[\s<>"'`]/.test(trimmed)) return null;
    if (trimmed.startsWith('/') || trimmed.startsWith('#')) return trimmed;
    try {
      const u = new URL(trimmed);
      if (u.protocol !== 'http:' && u.protocol !== 'https:') return null;
      return u.href;
    } catch {
      return null;
    }
  }

  function renderMarkdown(text) {
    // LLM output is untrusted — escape HTML before applying markdown rules.
    text = escapeHtml(text);

    function inlineFmt(s) {
      return s
        // Links: [text](url) — validate scheme, escape href. linkText is already HTML-escaped.
        .replace(/\[([^\]]+)\]\(([^)]+)\)/g, function(_, linkText, rawUrl) {
          const safe = safeUrl(rawUrl);
          if (!safe) return linkText;
          const href = escapeHtml(safe);
          if (safe.startsWith('/') || safe.startsWith('#')) {
            return `<a href="${href}">${linkText}</a>`;
          }
          return `<a href="${href}" target="_blank" rel="noopener">${linkText}</a>`;
        })
        // Bold
        .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
        // Italic
        .replace(/\*([^*]+)\*/g, '<em>$1</em>')
        // Inline code
        .replace(/`([^`]+)`/g, '<code>$1</code>');
    }

    // Normalize: treat single newlines between non-list/non-continuation lines as paragraph breaks
    // This handles Grok sending \n instead of \n\n between paragraphs
    const normalized = text.replace(/\n(?!\n)/g, (match, offset) => {
      const before = text.slice(Math.max(0, offset - 60), offset);
      const after = text.slice(offset + 1, offset + 10);
      // Keep single \n inside lists (next line starts with - * or digit.)
      if (/^[\s]*[-*]\s/.test(after) || /^[\s]*\d+\.\s/.test(after)) return '\n';
      // Keep single \n if previous line was a list item
      if (/[-*]\s[^\n]*$/.test(before) || /\d+\.\s[^\n]*$/.test(before)) return '\n';
      // Keep single \n inside blockquotes
      if (/^>/.test(after)) return '\n';
      // Otherwise promote to paragraph break
      return '\n\n';
    });

    return normalized
      .split('\n\n').map(p => p.trim()).filter(Boolean)
      .map(p => {
        // Bullet list
        if (/^[-*]\s/.test(p)) {
          const items = p.split(/\n/).filter(l => l.trim()).map(l => l.replace(/^[-*]\s+/, ''));
          return '<ul>' + items.map(i => `<li>${inlineFmt(i)}</li>`).join('') + '</ul>';
        }
        // Numbered list
        if (/^\d+\.\s/.test(p)) {
          const items = p.split(/\n/).filter(l => l.trim()).map(l => l.replace(/^\d+\.\s+/, ''));
          return '<ol>' + items.map(i => `<li>${inlineFmt(i)}</li>`).join('') + '</ol>';
        }
        // Blockquote
        if (p.startsWith('>')) {
          const content = p.split('\n').map(l => l.replace(/^>\s?/, '')).join(' ');
          return `<blockquote>${inlineFmt(content)}</blockquote>`;
        }
        // Header
        if (p.startsWith('### ')) return `<h4>${inlineFmt(p.slice(4))}</h4>`;
        if (p.startsWith('## ')) return `<h3>${inlineFmt(p.slice(3))}</h3>`;
        // Regular paragraph
        return `<p>${inlineFmt(p)}</p>`;
      })
      .join('');
  }
})();
</script>
