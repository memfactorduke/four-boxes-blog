---
interface Props {
  items: string[];
  basePath: string;
  variant?: 'default' | 'gold' | 'navy';
}

const { items, basePath, variant = 'default' } = Astro.props;

function formatLabel(item: string): string {
  return item.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
}

const variantClasses = {
  default: 'bg-white border border-cream-dark text-ink hover:border-gold/40',
  gold: 'bg-gold/10 text-gold-dark hover:bg-gold/20',
  navy: 'bg-navy text-white hover:bg-navy-light',
};
---

<div class="flex flex-wrap gap-2">
  {items.map(item => (
    <a
      href={`${basePath}/${item.toLowerCase().replace(/\s+/g, '-')}`}
      class={`px-3 py-1 rounded text-sm font-[Outfit] transition-colors ${variantClasses[variant]}`}
    >
      {formatLabel(item)}
    </a>
  ))}
</div>
