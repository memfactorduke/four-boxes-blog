---
interface Props {
  items: string[];
  basePath: string;
  variant?: 'default' | 'brass' | 'obsidian';
}

const { items, basePath, variant = 'default' } = Astro.props;

function formatLabel(item: string): string {
  return item.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
}

const variantClasses = {
  default: 'bg-white border border-parchment-dark text-gray-700 hover:border-brass',
  brass: 'bg-brass/15 text-brass-dark hover:bg-brass/25',
  obsidian: 'bg-obsidian text-white hover:bg-obsidian-light',
};
---

<div class="flex flex-wrap gap-2">
  {items.map(item => (
    <a
      href={`${basePath}/${item.toLowerCase().replace(/\s+/g, '-')}`}
      class={`font-[Figtree] px-3 py-1 rounded-sm text-sm transition-colors ${variantClasses[variant]}`}
    >
      {formatLabel(item)}
    </a>
  ))}
</div>
