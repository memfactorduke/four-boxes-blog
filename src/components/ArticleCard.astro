---
interface Props {
  title: string;
  date: string;
  slug: string;
  thumbnail: string;
  duration: string;
  legal_topics: string[];
  content_type: string[];
  court_level: string[];
  circuits: string[];
  states: string[];
  federal: boolean;
}

const { title, date, slug, thumbnail, duration, legal_topics, content_type, court_level, circuits, states, federal } = Astro.props;

const d = new Date(date + 'T00:00:00');
const formattedDate = `${d.getMonth() + 1}/${d.getDate()}/${String(d.getFullYear()).slice(2)}`;

function formatTopic(topic: string): string {
  return topic.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
}

function normalizeCircuit(circuit: string): string {
  const lower = circuit.toLowerCase().replace(/[-_\s]+/g, ' ').trim();
  if (lower.includes('d.c') || lower.includes('dc') || lower === 'd.c.') return 'D.C. Circuit';
  const ordinals: Record<string, string> = {
    '1st': 'First', 'first': 'First',
    '2nd': 'Second', 'second': 'Second',
    '3rd': 'Third', 'third': 'Third',
    '4th': 'Fourth', 'fourth': 'Fourth',
    '5th': 'Fifth', 'fifth': 'Fifth',
    '6th': 'Sixth', 'sixth': 'Sixth',
    '7th': 'Seventh', 'seventh': 'Seventh',
    '8th': 'Eighth', 'eighth': 'Eighth',
    '9th': 'Ninth', 'ninth': 'Ninth',
    '10th': 'Tenth', 'tenth': 'Tenth',
    '11th': 'Eleventh', 'eleventh': 'Eleventh',
  };
  for (const [key, name] of Object.entries(ordinals)) {
    if (lower.includes(key)) return `${name} Circuit`;
  }
  if (circuit.includes('Circuit')) return circuit;
  return circuit;
}

function getJurisdiction(): string {
  for (const cl of court_level) {
    const lower = cl.toLowerCase();
    if (lower === 'scotus' || lower.includes('supreme court') || lower === 'supreme-court' || lower === 'us-supreme-court') {
      return 'Supreme Court';
    }
  }
  if (circuits.length > 0) return normalizeCircuit(circuits[0]);
  for (const cl of court_level) {
    const lower = cl.toLowerCase();
    if (lower.includes('circuit') || lower.includes('appeals') || lower.includes('appellate')) return 'Federal Appeals';
    if (lower.includes('district')) return 'Federal District';
  }
  if (states.length > 0) return states[0];
  for (const cl of court_level) {
    const lower = cl.toLowerCase();
    if (lower.includes('executive') || lower.includes('agency') || lower.includes('legislature')) return 'Federal';
    if (lower.includes('state')) return 'State';
    if (lower.includes('federal')) return 'Federal';
  }
  if (federal) return 'Federal';
  return '';
}

const jurisdiction = getJurisdiction();
const primaryTopic = legal_topics[0] ? formatTopic(legal_topics[0]) : '';
---

<article class="card-lift group rounded-md overflow-hidden bg-white border border-parchment-dark hover:border-brass/25 relative">
  <!-- Brass left-border on hover -->
  <div class="absolute left-0 top-0 bottom-0 w-[3px] bg-brass opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
  <a href={`/articles/${slug}`} class="block">
    <div class="relative overflow-hidden">
      <img
        src={thumbnail}
        alt={title}
        class="w-full aspect-video object-cover transition-transform duration-700 group-hover:scale-105"
        loading="lazy"
      />
      <!-- Gradient overlay -->
      <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent opacity-60"></div>

      <span class="absolute bottom-2.5 right-2.5 bg-obsidian/80 text-white/90 text-[11px] font-[Figtree] px-2 py-0.5 rounded-sm backdrop-blur-sm font-medium tabular-nums">
        {duration}
      </span>
      {content_type[0] && (
        <span class="absolute top-2.5 left-2.5 bg-brass/90 text-obsidian text-[10px] font-[Figtree] font-bold px-2 py-0.5 rounded-sm uppercase tracking-wide backdrop-blur-sm">
          {formatTopic(content_type[0])}
        </span>
      )}
    </div>
    <div class="p-4 pt-3.5">
      <div class="flex items-center gap-2 mb-2 text-[11px]">
        <time class="text-warm-gray font-[Figtree] font-medium tracking-wide">{formattedDate}</time>
        {jurisdiction && (
          <>
            <span class="w-1 h-1 rounded-full bg-gray-light flex-shrink-0"></span>
            <span class="text-obsidian/60 font-[Figtree] font-medium truncate">{jurisdiction}</span>
          </>
        )}
        {primaryTopic && (
          <>
            <span class="w-1 h-1 rounded-full bg-brass/50 flex-shrink-0"></span>
            <span class="text-brass-dark font-[Figtree] font-semibold truncate">{primaryTopic}</span>
          </>
        )}
      </div>
      <h2 class="font-[Fraunces] text-[15px] font-bold text-obsidian leading-snug group-hover:text-brass-dark transition-colors line-clamp-2 min-h-[2.6rem]">
        {title}
      </h2>
    </div>
  </a>
</article>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
