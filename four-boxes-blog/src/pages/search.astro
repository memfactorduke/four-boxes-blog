---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles'))
  .sort((a, b) => b.data.date.localeCompare(a.data.date));

const topicCounts = new Map<string, number>();
for (const a of articles) {
  for (const t of a.data.legal_topics) {
    topicCounts.set(t, (topicCounts.get(t) || 0) + 1);
  }
}
const popularTopics = [...topicCounts.entries()].sort((a, b) => b[1] - a[1]).slice(0, 12);
const recentArticles = articles.slice(0, 6);

function formatTopic(t: string) {
  return t.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
}
---

<BaseLayout title="Search" description="Search Second Amendment legal analysis articles">
  <!-- Hero with integrated search -->
  <div style="background: radial-gradient(ellipse at 50% 30%, #162040 0%, #0b1528 70%)">
    <div class="max-w-4xl mx-auto px-5 lg:px-8 pt-12 pb-16">
      <div class="text-xs text-gold font-semibold tracking-[0.2em] uppercase mb-2 animate-fade-up">Find</div>
      <h1 class="font-[Cormorant_Garamond] text-4xl font-bold text-white tracking-tight mb-3 animate-fade-up stagger-1">Search Articles</h1>
      <p class="text-white/50 text-sm font-[Spectral] italic mb-8 animate-fade-up stagger-2">Search across {articles.length} articles, cases, and legal topics.</p>

      <!-- Search box in the hero -->
      <div class="animate-fade-up stagger-3">
        <div id="search-hero" class="search-in-hero"></div>
      </div>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-5 lg:px-8 py-10">
    <!-- Search results appear here -->
    <div id="search-results"></div>

    <!-- Quick browse (visible before search) -->
    <div id="browse-section">
      <!-- Popular topics -->
      <div class="mb-10">
        <h2 class="font-[Cormorant_Garamond] text-xs font-bold text-navy/50 uppercase tracking-[0.15em] mb-4 flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M9.568 3H5.25A2.25 2.25 0 0 0 3 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 0 0 5.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 0 0 9.568 3Z"/><path d="M6 6h.008v.008H6V6Z"/></svg>
          Popular Topics
        </h2>
        <div class="flex flex-wrap gap-2">
          {popularTopics.map(([topic, count]) => (
            <a
              href={`/topics/${topic}`}
              class="group flex items-center gap-2 bg-white border border-cream-dark border-l-2 border-l-transparent rounded-md px-4 py-2.5 hover:border-gold/30 hover:bg-gold/5 hover:border-l-gold transition-all"
            >
              <span class="font-[Outfit] text-sm font-medium text-navy group-hover:text-gold-dark transition-colors capitalize">
                {formatTopic(topic)}
              </span>
              <span class="font-[Outfit] text-[10px] text-gray-warm bg-cream px-1.5 py-0.5 rounded-full">{count}</span>
            </a>
          ))}
        </div>
      </div>

      <!-- Recent articles -->
      <div>
        <h2 class="text-xs font-bold text-navy/50 uppercase tracking-[0.15em] mb-4 flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
          Recent Articles
        </h2>
        <div class="space-y-3">
          {recentArticles.map(article => (
            <a href={`/articles/${article.id}`} class="group flex items-center gap-4 bg-white border border-cream-dark rounded-lg p-3 hover:border-gold/25 hover:shadow-sm transition-all">
              <img
                src={article.data.thumbnail}
                alt=""
                class="w-20 h-14 object-cover rounded-lg shrink-0"
                loading="lazy"
              />
              <div class="min-w-0 flex-1">
                <h3 class="font-[Cormorant_Garamond] text-sm font-semibold text-navy group-hover:text-gold-dark transition-colors leading-snug line-clamp-2">
                  {article.data.title}
                </h3>
                <time class="font-[Outfit] text-[11px] text-gray-warm mt-0.5 block">
                  {new Date(article.data.date + 'T00:00:00').toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                </time>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<style is:global>
  /* Pagefind in hero - dark background variant */
  .search-in-hero .pagefind-ui {
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary: #c4993d;
    --pagefind-ui-text: #ffffff;
    --pagefind-ui-background: transparent;
    --pagefind-ui-border: rgba(255,255,255,0.2);
    --pagefind-ui-border-width: 1.5px;
    --pagefind-ui-border-radius: 8px;
    --pagefind-ui-font: 'Outfit', 'Helvetica Neue', sans-serif;
  }
  .search-in-hero .pagefind-ui__search-input {
    background: rgba(255,255,255,0.08) !important;
    color: white !important;
    font-weight: 400 !important;
    font-family: 'Outfit', 'Helvetica Neue', sans-serif !important;
    padding: 1.1rem 1.35rem 1.1rem 3rem !important;
    font-size: 1rem !important;
    border: 1.5px solid rgba(255,255,255,0.15) !important;
    border-radius: 8px !important;
  }
  .search-in-hero .pagefind-ui__search-input::placeholder {
    color: rgba(255,255,255,0.55) !important;
    font-family: 'Outfit', 'Helvetica Neue', sans-serif !important;
  }
  /* Move search icon so it doesn't overlap text */
  .search-in-hero .pagefind-ui__search-icon {
    left: 0.85rem !important;
    opacity: 0.6 !important;
  }
  .search-in-hero .pagefind-ui__search-input:focus {
    border-color: #c4993d !important;
    outline: none !important;
    box-shadow: 0 0 0 2px rgba(196, 153, 61, 0.15) !important;
    background: rgba(255,255,255,0.12) !important;
  }
  .search-in-hero .pagefind-ui__search-clear {
    color: rgba(255,255,255,0.5) !important;
  }
  /* Hide the results container in hero - we show them below */
  .search-in-hero .pagefind-ui__results-area {
    display: none !important;
  }

  /* Results area below hero */
  #search-results .pagefind-ui {
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary: #c4993d;
    --pagefind-ui-text: #0b1528;
    --pagefind-ui-background: #fcfbf7;
    --pagefind-ui-border: #ede8dc;
    --pagefind-ui-tag: #f8f5ee;
    --pagefind-ui-border-width: 1.5px;
    --pagefind-ui-border-radius: 8px;
    --pagefind-ui-image-border-radius: 8px;
    --pagefind-ui-image-box-ratio: 16 / 9;
    --pagefind-ui-font: 'Outfit', 'Helvetica Neue', sans-serif;
  }
  #search-results .pagefind-ui__search-input {
    display: none !important;
  }
  #search-results .pagefind-ui__result {
    padding: 1rem 0 !important;
    border-bottom: 1px solid #ede8dc !important;
  }
  #search-results .pagefind-ui__result-link {
    color: #0b1528 !important;
    font-weight: 700 !important;
    font-family: 'Cormorant Garamond', Georgia, serif !important;
    font-size: 1.1rem !important;
  }
  #search-results .pagefind-ui__result-link:hover {
    color: #c4993d !important;
  }
  #search-results .pagefind-ui__result-excerpt {
    font-family: 'Spectral', Georgia, serif !important;
    line-height: 1.8 !important;
    color: #4b5060 !important;
    font-size: 0.9rem !important;
  }
  #search-results .pagefind-ui__button {
    background: #0b1528 !important;
    border-radius: 8px !important;
    font-family: 'Outfit', 'Helvetica Neue', sans-serif !important;
    font-weight: 600 !important;
  }
  #search-results .pagefind-ui__button:hover {
    background: #162040 !important;
  }
  #search-results .pagefind-ui__message {
    font-weight: 500 !important;
    padding: 1rem 0 !important;
  }
</style>

<script is:inline>
  window.addEventListener('DOMContentLoaded', () => {
    const browseSection = document.getElementById('browse-section');

    // Hero search input
    const heroSearch = new PagefindUI({
      element: '#search-hero',
      showSubResults: false,
      showImages: false,
      resetStyles: false,
    });

    // Results area
    const resultsSearch = new PagefindUI({
      element: '#search-results',
      showSubResults: true,
      showImages: true,
      resetStyles: false,
    });

    // Sync hero input to results
    const heroInput = document.querySelector('#search-hero .pagefind-ui__search-input');
    if (heroInput) {
      heroInput.addEventListener('input', (e) => {
        const query = e.target.value;
        // Trigger search in results area
        const resultsInput = document.querySelector('#search-results .pagefind-ui__search-input');
        if (resultsInput) {
          resultsInput.value = query;
          resultsInput.dispatchEvent(new Event('input', { bubbles: true }));
        }
        // Toggle browse section
        if (browseSection) {
          browseSection.style.display = query.length > 0 ? 'none' : '';
        }
      });

      // Focus the hero input on page load
      heroInput.focus();
    }
  });
</script>
