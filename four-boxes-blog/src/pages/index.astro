---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles'))
  .sort((a, b) => b.data.date.localeCompare(a.data.date));

const featuredArticle = articles[0];
const remainingArticles = articles.slice(1);
const allTopics = [...new Set(articles.flatMap(a => a.data.legal_topics))];
const totalCases = [...new Set(articles.flatMap(a => a.data.cases_discussed.map(c => c.name)))].length;
---

<BaseLayout title="Home" description="Second Amendment legal analysis — court rulings, case breakdowns, and scholarly commentary by constitutional attorney Mark W. Smith.">
  <!-- Hero -->
  <section class="relative text-white overflow-hidden" style="background: radial-gradient(ellipse at 20% 40%, #162040 0%, #0b1528 60%, #060c18 100%)">
    <!-- Geometric crosshatch pattern overlay -->
    <div class="absolute inset-0 opacity-[0.02]" style="background-image: url(&quot;data:image/svg+xml,%3Csvg width='40' height='40' viewBox='0 0 40 40' xmlns='http://www.w3.org/2000/svg'%3E%3Cline x1='0' y1='0' x2='40' y2='40' stroke='%23ffffff' stroke-width='0.3'/%3E%3Cline x1='40' y1='0' x2='0' y2='40' stroke='%23ffffff' stroke-width='0.3'/%3E%3Cline x1='20' y1='0' x2='20' y2='40' stroke='%23ffffff' stroke-width='0.2'/%3E%3Cline x1='0' y1='20' x2='40' y2='20' stroke='%23ffffff' stroke-width='0.2'/%3E%3C/svg%3E&quot;);"></div>

    <div class="max-w-7xl mx-auto px-5 lg:px-8 py-20 md:py-28 relative">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div>
          <div class="animate-fade-up">
            <div class="inline-flex items-center gap-2 text-gold text-xs font-[Outfit] font-semibold tracking-[0.2em] uppercase mb-6">
              <div class="w-16 h-px bg-gold"></div>
              Constitutional Law
            </div>
          </div>

          <h1 class="animate-fade-up stagger-1 font-[Cormorant_Garamond] text-5xl lg:text-7xl font-bold leading-[1.1] mb-6 tracking-tight" style="text-wrap: balance">
            Second Amendment<br />
            <span class="hero-shimmer text-transparent bg-clip-text bg-gradient-to-r from-gold-light via-gold to-gold-dark">Legal Analysis</span>
          </h1>

          <p class="animate-fade-up stagger-2 font-[Spectral] italic text-lg lg:text-xl text-white/55 leading-relaxed mb-8 max-w-lg">
            Scholarly analysis of court rulings, case developments, and legislative changes affecting the right to keep and bear arms — by constitutional attorney <strong class="text-white/90 not-italic">Mark W. Smith</strong>.
          </p>

          <div class="animate-fade-up stagger-3 flex flex-col sm:flex-row gap-3">
            <a href="/search"
              class="group inline-flex items-center justify-center gap-2 bg-navy text-gold border-b-2 border-gold px-6 py-3 rounded-sm font-[Outfit] font-semibold text-sm uppercase tracking-[0.1em] hover:bg-navy-light transition-all">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
              Search Articles
            </a>
            <a href="https://www.youtube.com/@TheFourBoxesDiner" target="_blank" rel="noopener"
              class="inline-flex items-center justify-center gap-2 border border-gold text-gold px-6 py-3 rounded-sm font-[Outfit] font-semibold text-sm uppercase tracking-[0.1em] hover:bg-gold hover:text-navy transition-all">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M23.5 6.19a3.02 3.02 0 00-2.12-2.14C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.38.55A3.02 3.02 0 00.5 6.19 31.97 31.97 0 000 12a31.97 31.97 0 00.5 5.81 3.02 3.02 0 002.12 2.14c1.88.55 9.38.55 9.38.55s7.5 0 9.38-.55a3.02 3.02 0 002.12-2.14A31.97 31.97 0 0024 12a31.97 31.97 0 00-.5-5.81zM9.75 15.02V8.98L15.5 12l-5.75 3.02z"/></svg>
              Watch on YouTube
            </a>
          </div>

          <!-- Stats bar -->
          <div class="animate-fade-up stagger-4 flex items-center gap-4 sm:gap-6 mt-10 pt-8 border-t border-white/10">
            <div>
              <div class="text-3xl font-bold font-[Cormorant_Garamond] text-gold">{articles.length}</div>
              <div class="text-[10px] sm:text-xs font-[Outfit] text-white/40 uppercase tracking-[0.15em]">Articles</div>
            </div>
            <div class="w-px h-8 bg-gold/30"></div>
            <div>
              <div class="text-3xl font-bold font-[Cormorant_Garamond] text-gold">{totalCases}</div>
              <div class="text-[10px] sm:text-xs font-[Outfit] text-white/40 uppercase tracking-[0.15em]">Cases</div>
            </div>
            <div class="w-px h-8 bg-gold/30"></div>
            <div>
              <div class="text-3xl font-bold font-[Cormorant_Garamond] text-gold">{allTopics.length}</div>
              <div class="text-[10px] sm:text-xs font-[Outfit] text-white/40 uppercase tracking-[0.15em]">Topics</div>
            </div>
          </div>
        </div>

        <!-- Featured article card -->
        {featuredArticle && (
          <div class="animate-fade-up stagger-3 hidden lg:block">
            <a href={`/articles/${featuredArticle.id}`} class="group block relative">
              <div class="absolute -inset-3 bg-gradient-to-br from-gold/20 via-transparent to-gold/10 rounded-2xl blur-sm group-hover:blur-md transition-all"></div>
              <div class="relative bg-navy-light rounded-xl overflow-hidden border border-gold/20 group-hover:border-gold/40 transition-all">
                <div class="relative">
                  <img
                    src={featuredArticle.data.thumbnail}
                    alt={featuredArticle.data.title}
                    class="w-full aspect-video object-cover opacity-80 group-hover:opacity-90 transition-opacity"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-navy-light via-transparent"></div>
                  <div class="absolute top-3 left-3 flex gap-2">
                    <span class="bg-gold text-navy text-[10px] font-[Outfit] font-bold px-2.5 py-1 rounded-sm uppercase tracking-[0.15em] backdrop-blur-sm">
                      Latest Analysis
                    </span>
                  </div>
                  <span class="absolute bottom-3 right-3 bg-black/60 text-white/90 text-xs px-2 py-0.5 rounded backdrop-blur-sm">
                    {featuredArticle.data.duration}
                  </span>
                </div>
                <div class="p-5">
                  <time class="text-[11px] font-[Outfit] text-white/40 uppercase tracking-[0.15em]">
                    {new Date(featuredArticle.data.date + 'T00:00:00').toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </time>
                  <h2 class="font-[Cormorant_Garamond] text-lg font-bold text-white mt-1.5 leading-snug group-hover:text-gold transition-colors">
                    {featuredArticle.data.title}
                  </h2>
                  <div class="flex items-center gap-2 mt-3 text-xs font-[Outfit] text-gold/70 font-medium group-hover:text-gold transition-colors uppercase tracking-wider">
                    Read article
                    <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
                  </div>
                </div>
              </div>
            </a>
          </div>
        )}
      </div>
    </div>

    <!-- Bottom gradient fade -->
    <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-paper to-transparent"></div>
  </section>

  <!-- Hero shimmer animation -->
  <style>
    @keyframes hero-shimmer {
      0% { background-position: -200% center; }
      100% { background-position: 200% center; }
    }
    .hero-shimmer {
      background-size: 200% auto;
      animation: hero-shimmer 2s ease-in-out 0.5s 1 forwards;
    }
  </style>

  <!-- Articles with Filters -->
  <section class="max-w-7xl mx-auto px-5 lg:px-8 py-16">
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-6" data-animate>
      <div>
        <div class="text-xs text-gold font-semibold tracking-[0.2em] uppercase mb-2">Analysis</div>
        <h2 class="font-[Playfair_Display] text-3xl font-bold text-navy tracking-tight">Articles</h2>
      </div>
      <div class="flex items-center gap-3">
        <select id="sort-select" class="text-sm bg-white border border-gray-200 rounded-lg px-3 py-2 text-navy focus:outline-none focus:border-gold cursor-pointer">
          <option value="newest">Newest First</option>
          <option value="oldest">Oldest First</option>
        </select>
        <a href="/rss.xml" class="hidden sm:flex items-center gap-1.5 text-sm text-gray-warm hover:text-gold-dark transition-colors group">
          <svg class="w-4 h-4 group-hover:scale-110 transition-transform" fill="currentColor" viewBox="0 0 24 24">
            <path d="M6.18 15.64a2.18 2.18 0 010 4.36 2.18 2.18 0 010-4.36zM4 4.44A15.56 15.56 0 0119.56 20h-2.83A12.73 12.73 0 004 7.27V4.44zm0 5.66a9.9 9.9 0 019.9 9.9h-2.83A7.07 7.07 0 004 12.93V10.1z"/>
          </svg>
          RSS
        </a>
      </div>
    </div>

    <!-- Filter bar -->
    <div class="flex flex-wrap gap-2 mb-8 pb-6 border-b border-gray-100" data-animate>
      <button data-filter="all" class="filter-btn active text-xs bg-navy text-white px-3 py-1.5 rounded-lg font-medium transition-all">All</button>
      {[...new Set(articles.flatMap(a => a.data.content_type))].map(type => (
        <button data-filter={`type:${type}`} class="filter-btn text-xs bg-cream text-navy/70 px-3 py-1.5 rounded-lg font-medium hover:bg-gold/15 transition-all capitalize">
          {type.replace(/-/g, ' ')}
        </button>
      ))}
      <div class="w-px h-6 bg-gray-200 self-center mx-1"></div>
      {[...new Set(articles.flatMap(a => a.data.court_level))].filter(Boolean).slice(0, 5).map(court => (
        <button data-filter={`court:${court}`} class="filter-btn text-xs bg-cream text-navy/70 px-3 py-1.5 rounded-lg font-medium hover:bg-gold/15 transition-all">
          {court}
        </button>
      ))}
    </div>

    <div id="articles-grid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-7">
      {articles.map((article, i) => (
        <div
          class={`article-item ${i >= 24 ? 'hidden' : ''}`}
          data-date={article.data.date}
          data-types={article.data.content_type.join(',')}
          data-courts={article.data.court_level.join(',')}
          data-topics={article.data.legal_topics.join(',')}
          data-index={i}
        >
          <ArticleCard
            title={article.data.title}
            date={article.data.date}
            slug={article.id}
            thumbnail={article.data.thumbnail}
            duration={article.data.duration}
            legal_topics={article.data.legal_topics}
            content_type={article.data.content_type}
            court_level={article.data.court_level}
            circuits={article.data.circuits}
            states={article.data.states}
            federal={article.data.federal}
          />
        </div>
      ))}
    </div>

    <div id="load-more-container" class="text-center mt-10">
      <button id="load-more-btn" class="bg-navy text-white px-8 py-3 rounded-xl text-sm font-semibold hover:bg-navy-light transition-colors">
        Load More Articles
        <span id="load-more-count" class="text-white/50 ml-1">({articles.length - 24} remaining)</span>
      </button>
    </div>

    <div id="no-results" class="hidden text-center py-12 text-gray-warm">
      <p class="text-sm">No articles match this filter.</p>
    </div>
  </section>

  <script is:inline>
  (function() {
    const grid = document.getElementById('articles-grid');
    const items = [...document.querySelectorAll('.article-item')];
    const noResults = document.getElementById('no-results');
    const sortSelect = document.getElementById('sort-select');
    const filterBtns = document.querySelectorAll('.filter-btn');
    const loadMoreBtn = document.getElementById('load-more-btn');
    const loadMoreContainer = document.getElementById('load-more-container');
    const loadMoreCount = document.getElementById('load-more-count');
    const PAGE_SIZE = 24;
    let activeFilter = 'all';
    let visibleCount = PAGE_SIZE;

    // Filter
    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        filterBtns.forEach(b => {
          b.classList.remove('active', 'bg-navy', 'text-white');
          b.classList.add('bg-cream', 'text-navy/70');
        });
        btn.classList.add('active', 'bg-navy', 'text-white');
        btn.classList.remove('bg-cream', 'text-navy/70');
        activeFilter = btn.dataset.filter;
        visibleCount = PAGE_SIZE; // Reset pagination on filter change
        applyFilters();
      });
    });

    // Sort
    sortSelect.addEventListener('change', () => {
      visibleCount = PAGE_SIZE;
      applyFilters();
    });

    // Load More
    loadMoreBtn.addEventListener('click', () => {
      visibleCount += PAGE_SIZE;
      applyFilters();
    });

    function applyFilters() {
      let matchCount = 0;
      let shownCount = 0;
      const isOldest = sortSelect.value === 'oldest';

      // Sort items
      const sorted = [...items].sort((a, b) => {
        const da = a.dataset.date, db = b.dataset.date;
        return isOldest ? da.localeCompare(db) : db.localeCompare(da);
      });

      sorted.forEach(item => {
        let matchesFilter = true;
        if (activeFilter !== 'all') {
          const [filterType, filterVal] = activeFilter.split(':');
          if (filterType === 'type') matchesFilter = item.dataset.types.includes(filterVal);
          if (filterType === 'court') matchesFilter = item.dataset.courts.includes(filterVal);
          if (filterType === 'topic') matchesFilter = item.dataset.topics.includes(filterVal);
        }

        if (matchesFilter) {
          matchCount++;
          if (matchCount <= visibleCount) {
            item.classList.remove('hidden');
            item.style.display = '';
            shownCount++;
          } else {
            item.classList.add('hidden');
            item.style.display = 'none';
          }
        } else {
          item.classList.add('hidden');
          item.style.display = 'none';
        }
        grid.appendChild(item);
      });

      // Update load more button
      const remaining = matchCount - shownCount;
      if (remaining > 0) {
        loadMoreContainer.classList.remove('hidden');
        loadMoreCount.textContent = '(' + remaining + ' remaining)';
      } else {
        loadMoreContainer.classList.add('hidden');
      }

      noResults.classList.toggle('hidden', shownCount > 0);
    }

    // Initial state — hide load more if fewer than PAGE_SIZE total
    if (items.length <= PAGE_SIZE) {
      loadMoreContainer.classList.add('hidden');
    }
  })();
  </script>

  <!-- Email Capture -->
  <section class="relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-5 lg:px-8 py-20">
      <div class="relative bg-navy rounded-2xl overflow-hidden" data-animate>
        <!-- Decorative elements -->
        <div class="absolute top-0 right-0 w-64 h-64 bg-gold/5 rounded-full -translate-y-1/2 translate-x-1/3 blur-2xl"></div>
        <div class="absolute bottom-0 left-0 w-48 h-48 bg-gold/5 rounded-full translate-y-1/2 -translate-x-1/4 blur-2xl"></div>
        <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold/30 to-transparent"></div>

        <div class="relative px-8 py-14 md:px-14 md:py-16 text-center max-w-2xl mx-auto">
          <div class="inline-flex items-center gap-2 text-gold text-xs font-semibold tracking-[0.2em] uppercase mb-5">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/>
            </svg>
            Stay Informed
          </div>

          <h2 class="font-[Playfair_Display] text-3xl md:text-4xl font-bold text-white mb-4 tracking-tight">
            Weekly 2A Legal Briefing
          </h2>
          <p class="text-white/50 text-sm md:text-base leading-relaxed mb-8 font-[Newsreader]">
            Get a curated digest of the latest Second Amendment court decisions, case developments, and legislative analysis delivered to your inbox every week.
          </p>

          <form id="email-form" name="newsletter" method="POST" data-netlify="true" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
            <input type="hidden" name="form-name" value="newsletter" />
            <div class="flex-1 relative">
              <input
                type="email"
                name="email"
                id="email-input"
                placeholder="you@example.com"
                required
                class="w-full bg-white/8 border border-white/15 rounded-lg px-4 py-3 text-sm text-white placeholder:text-white/30 focus:outline-none focus:border-gold/50 focus:ring-2 focus:ring-gold/15 transition-all"
              />
            </div>
            <button
              type="submit"
              id="email-submit"
              class="bg-gradient-to-r from-gold-dark to-gold text-navy px-6 py-3 rounded-lg text-sm font-semibold hover:shadow-xl hover:shadow-gold/20 transition-all hover:scale-[1.02] active:scale-[0.98] whitespace-nowrap"
            >
              Subscribe
            </button>
          </form>

          <p class="text-white/25 text-xs mt-4">No spam. Unsubscribe anytime. Free forever.</p>

          <!-- Success message (hidden by default) -->
          <div id="email-success" class="hidden mt-6">
            <div class="inline-flex items-center gap-2 bg-gold/15 text-gold px-4 py-2.5 rounded-lg text-sm font-medium">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg>
              You're on the list. Welcome aboard.
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Browse by Topic -->
  {allTopics.length > 0 && (
    <section class="max-w-7xl mx-auto px-5 lg:px-8 pb-20">
      <div class="gold-rule mb-14"></div>
      <div data-animate>
        <div class="text-xs text-gold font-semibold tracking-[0.2em] uppercase mb-2">Explore</div>
        <h2 class="font-[Playfair_Display] text-3xl font-bold text-navy mb-8 tracking-tight">Browse by Topic</h2>
      </div>
      <div class="flex flex-wrap gap-2.5" data-animate>
        {allTopics.map(topic => (
          <a
            href={`/topics/${topic}`}
            class="group relative bg-cream border border-cream-dark text-navy px-5 py-2.5 rounded-lg text-sm font-medium hover:border-gold/40 hover:bg-gold/8 transition-all capitalize"
          >
            {topic.replace(/-/g, ' ')}
            <span class="absolute inset-0 rounded-lg bg-gradient-to-r from-gold/0 via-gold/5 to-gold/0 opacity-0 group-hover:opacity-100 transition-opacity"></span>
          </a>
        ))}
      </div>
    </section>
  )}

  <script is:inline>
    document.getElementById('email-form')?.addEventListener('submit', async function(e) {
      e.preventDefault();
      const btn = document.getElementById('email-submit');
      const input = document.getElementById('email-input');
      const success = document.getElementById('email-success');

      btn.textContent = 'Subscribing...';
      btn.disabled = true;

      try {
        await fetch('/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams(new FormData(this)).toString(),
        });
        this.style.display = 'none';
        success.classList.remove('hidden');
        success.classList.add('animate-fade-up');
      } catch {
        btn.textContent = 'Try Again';
        btn.disabled = false;
      }
    });
  </script>
</BaseLayout>
