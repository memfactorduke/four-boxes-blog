---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  const caseMap = new Map<string, { name: string; citation?: string; court?: string; articles: typeof articles }>();

  for (const article of articles) {
    for (const c of article.data.cases_discussed) {
      const slug = c.name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
      if (!caseMap.has(slug)) {
        caseMap.set(slug, { name: c.name, citation: c.citation, court: c.court, articles: [] });
      }
      caseMap.get(slug)!.articles.push(article);
    }
  }

  return Array.from(caseMap.entries()).map(([slug, data]) => ({
    params: { case: slug },
    props: {
      caseName: data.name,
      citation: data.citation,
      court: data.court,
      articles: data.articles.sort((a, b) => b.data.date.localeCompare(a.data.date)),
    },
  }));
}

const { caseName, citation, court, articles } = Astro.props;
---

<BaseLayout title={caseName} description={`Analysis of ${caseName}`}>
  <div class="bg-navy">
    <div class="max-w-7xl mx-auto px-5 lg:px-8 py-12">
      <nav class="font-[Outfit] text-xs text-white/40 mb-4 flex items-center gap-2 animate-fade-in">
        <a href="/" class="hover:text-gold transition-colors">Home</a>
        <svg class="w-3 h-3 text-gold/50" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg>
        <span>Cases</span>
        <svg class="w-3 h-3 text-gold/50" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg>
        <span class="text-white/60 truncate max-w-xs"><em>{caseName}</em></span>
      </nav>

      <h1 class="font-[Spectral] text-3xl font-medium text-white tracking-tight italic animate-fade-up"><em>{caseName}</em></h1>
      <div class="flex items-center gap-3 mt-3 animate-fade-up stagger-1">
        {citation && <span class="font-[Outfit] text-white/50 text-sm">{citation}</span>}
        {court && <span class="font-[Outfit] bg-navy-light text-gold text-[10px] font-bold px-2.5 py-1 rounded-sm uppercase tracking-wider">{court}</span>}
      </div>
      <p class="font-[Outfit] text-white/40 mt-3 text-sm animate-fade-up stagger-2">{articles.length} article{articles.length !== 1 ? 's' : ''} discussing this case</p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-5 lg:px-8 py-10">
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-7">
      {articles.map((article, i) => (
        <div data-animate class={`stagger-${Math.min(i + 1, 6)}`}>
          <ArticleCard
            title={article.data.title}
            date={article.data.date}
            slug={article.id}
            thumbnail={article.data.thumbnail}
            duration={article.data.duration}
            legal_topics={article.data.legal_topics}
            content_type={article.data.content_type}
            court_level={article.data.court_level}
            circuits={article.data.circuits}
            states={article.data.states}
            federal={article.data.federal}
          />
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
