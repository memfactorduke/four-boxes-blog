# Copy this file to `.env` and fill in the values you need.
# `.env` is gitignored — NEVER commit real keys.
#
# Tiers:
#   [pipeline]  needed locally to run the article pipeline
#   [optional]  improves output but has a fallback
#   [runtime]   only the deployed site needs these (set in Netlify env vars,
#               NOT required for writing articles locally)

# [pipeline] Google AI / Imagen 4 — article thumbnail generation.
# The ONLY key the local article pipeline actually needs.
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# [optional] Voyage AI — search-index embeddings (voyage-3-lite, 512-dim).
# Without it the build falls back to TF-IDF (still works). https://www.voyageai.com/
VOYAGE_API_KEY=

# [runtime] Chatbot — xAI Grok. Set in Netlify env for production.
XAI_API_KEY=

# [runtime] Chatbot — Perplexity. Set in Netlify env for production.
PERPLEXITY_API_KEY=

# [runtime] Admin dashboard auth token. Set in Netlify env for production.
ADMIN_TOKEN=

# [runtime] GoatCounter analytics. Set in Netlify env for production.
GOATCOUNTER_API_KEY=
